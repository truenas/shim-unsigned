#!/usr/bin/make -f

include /usr/share/dpkg/architecture.mk

cert=debian/truenas-uefi-ca.der
distributor=truenas

deb_version             := $(shell dpkg-parsechangelog | sed -ne "s/^Version: \(.*\)/\1/p")
upstream_version        := $(shell echo $(deb_version) | sed -e "s/-[^-]*$$//")
plain_upstream_version  := $(shell echo $(upstream_version) | sed -e "s/+dfsg.*//")

DBX_LIST = dbx.esl
DBX_HASHES = debian/$(distributor)-dbx.hashes
SBAT_IN = debian/sbat.$(distributor).csv.in
SBAT_DATA = data/sbat.$(distributor).csv

include /usr/share/dpkg/architecture.mk

ifeq ($(DEB_HOST_ARCH),amd64)
export EFI_ARCH := x64
endif
ifeq ($(DEB_HOST_ARCH),arm64)
export EFI_ARCH := aa64
endif
ifeq ($(DEB_HOST_ARCH),i386)
export EFI_ARCH := ia32
endif

EFI_ARCH_UPPER := $(shell echo $(EFI_ARCH) | tr 'a-z' 'A-Z')
PREBUILT       := debian/prebuilt/$(EFI_ARCH)

COMMON_OPTIONS += \
	RELEASE=$(plain_upstream_version) \
	COMMIT_ID=afc49558b34548644c1cd0ad1b6526a9470182ed \
	MAKELEVEL=0 \
	ENABLE_HTTPBOOT=true \
	VENDOR_CERT_FILE=$(cert) \
	VENDOR_DBX_FILE=$(DBX_LIST) \
	EFIDIR=$(distributor) \
	CROSS_COMPILE=$(DEB_HOST_GNU_TYPE)- \
	CC=$(DEB_HOST_GNU_TYPE)-gcc-14 \
	$(NULL)

# Force shim to use the latest revocations by default to block some
# older grub issues. This is:
# "shim,4\ngrub,5\n"
COMMON_OPTIONS += SBAT_AUTOMATIC_DATE=2025021800

$(DBX_LIST): $(DBX_HASHES)
	./debian/generate_dbx_list $(EFI_ARCH) $< $@

$(SBAT_DATA): $(SBAT_IN)
	rm -f $@
	set -e; \
	sed -e "s/@DEB_VERSION@/$(deb_version)/g" \
		-e "s/@UPSTREAM_VERSION@/$(plain_upstream_version)/g" \
		< $(SBAT_IN) > $(SBAT_DATA)
	# If we have an empty $(SBAT_DATA), delete
	if [ ! -s $(SBAT_DATA) ]; then rm -f $(SBAT_DATA); fi

%:
	dh $@

override_dh_auto_clean:
	dh_auto_clean -- MAKELEVEL=0
	rm -f $(DBX_LIST) $(SBAT_DATA) sbat.*.csv BOOT*.CSV
	rm -f test-csv test-sbat test-str test-load-options
	rm -f test-mock-variables test-mok-mirror test-pe-relocate test-pe-util

override_dh_auto_build: $(DBX_LIST) $(SBAT_DATA)
	# Ship prebuilt binaries instead of compiling, so shim-unsigned's
	# output bytes stay stable across Debian release upgrades. Downstream
	# secure-boot packages (shim-signed, shim-helpers-amd64-signed) are
	# bound to specific byte sequences of shim-unsigned, and MS re-signing
	# takes up to a year -- we cannot tolerate toolchain-induced drift in
	# that window.
	#
	# Regenerate on shim source / CA / dbx change: rebuild the Dockerfile
	# at https://github.com/truenas/shim-review (branch
	# truenas-shim-amd64-20260306, rhboot/shim-review#526) and copy
	# shim*.efi, mm*.efi, fb*.efi, BOOT*.CSV into debian/prebuilt/<efi_arch>/.
	install -m 0644 $(PREBUILT)/shim$(EFI_ARCH).efi       ./
	install -m 0644 $(PREBUILT)/mm$(EFI_ARCH).efi         ./
	install -m 0644 $(PREBUILT)/fb$(EFI_ARCH).efi         ./
	install -m 0644 $(PREBUILT)/BOOT$(EFI_ARCH_UPPER).CSV ./
	touch shim*.efi mm*.efi fb*.efi BOOT*.CSV

override_dh_auto_test:
	# Skip: tests require compiled test binaries.

override_dh_auto_install:
	# Skip `make install`: it would re-trigger a full source compile via
	# shim's Makefile dependency graph (install -> shim.efi -> .so -> .o's,
	# all wiped by override_dh_auto_clean). Place the prebuilt binaries
	# directly at the paths shim-unsigned.install expects.
	install -d debian/tmp/boot/efi/EFI/BOOT
	install -d debian/tmp/boot/efi/EFI/$(distributor)
	install -m 0644 shim$(EFI_ARCH).efi      debian/tmp/boot/efi/EFI/$(distributor)/
	install -m 0644 BOOT$(EFI_ARCH_UPPER).CSV debian/tmp/boot/efi/EFI/$(distributor)/
	install -m 0644 fb$(EFI_ARCH).efi        debian/tmp/boot/efi/EFI/BOOT/
	install -m 0644 mm$(EFI_ARCH).efi        debian/tmp/boot/efi/EFI/BOOT/
	install -m 0644 mm$(EFI_ARCH).efi        debian/tmp/boot/efi/EFI/$(distributor)/

	install -m 644 $(cert) debian/shim-unsigned/usr/share/shim

	# Generate the template packages that we'll use for SB signing later
	./debian/signing-template.generate

	# Log some useful things about the build here
	./debian/check_nx shim*.efi
	sha256sum *.efi

generate-gnu-efi:
	git -C gnu-efi archive --prefix=gnu-efi/ HEAD | xz -9 \
		> ../shim_$(plain_upstream_version).orig-gnu-efi.tar.xz
